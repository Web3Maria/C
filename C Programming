#include <stdio.h>

int main() {
    int a, b, sum;
    
    printf("Enter two integers: ");
    // scanf() reads the input from the keyboard
    scanf("%d %d", &a, &b);
    
    sum = a + b;
    printf("Sum: %d\n", sum);
    
    return 0;
}



require 'nokogiri'
require 'open-uri'

# Target URL
url = "https://ycombinator.com" 
html = URI.open(url)
doc = Nokogiri::HTML(html)

# Extract and print titles of top stories
puts "--- Today's Top Headlines ---"
doc.css('.titleline > a').each_with_index do |link, index|
  puts "#{index + 2}. #{link.content}"
end

class TodoList
  def initialize
    @tasks = []
  end

  def add(task)
    @tasks << task
    puts "Added: #{task}"
  end

  def show
    puts "\nYour Tasks:"
    @tasks.each_with_index { |t, i| puts "#{i + 1}. #{t}" }
  end
end

list = TodoList.new

loop do
  puts "\n[1] Add Task [2] View Tasks [3] Exit"
  choice = gets.chomp.to_i

  case choice
  when 1
    print "Enter task: "
    list.add(gets.chomp)
  when 2
    list.show
  when 3
    break
  else
    puts "Invalid option!"
  end
end

secret_number = rand(1..10)
attempts = 0
guess = 0

puts "Welcome to the Guessing Game!"
puts "I am thinking of a number between 1 and 10."

while guess != secret_number
  print "Enter your guess: "
  guess = gets.chomp.to_i
  attempts += 1

  if guess < secret_number
    puts "Too low! Try again."
  elsif guess > secret_number
    puts "Too high! Try again."
  else
    puts "Congratulations! You guessed the number in #{attempts} attempts."
  end
end
